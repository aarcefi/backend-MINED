// ---------------------------------------------------------
// Configuración de conexión a PostgreSQL
// ---------------------------------------------------------
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------
enum TipoPersona {
  MADRE
  PADRE
  TUTOR
  FUNCIONARIO
  TRABAJADOR_SOCIAL
}

enum TipoSolicitud {
  TRABAJADOR
  ESTUDIANTE
  CASO_SOCIAL
}

enum SectorPrioridad {
  SALUD
  EDUCACION
  DEFENSA
  CASO_SOCIAL
  OTRO
}

enum EstadoSolicitud {
  RECIBIDA
  EN_REVISION
  APROBADA
  RECHAZADA
  EN_ESPERA
}

enum TipoDocumento {
  CARNET
  TARJETA_MENOR
  CARTA_LABORAL
  CARTA_ESTUDIO
  INFORME_SOCIAL
}

enum VinculoLaboral {
  ACTIVO
  ESTUDIANTE
  PERDIDO
}

enum TipoCirculo {
  NORMAL
  ESPECIAL
  MIXTO
}

enum ResultadoDecision {
  ACEPTADA
  DENEGADA
}

enum EstadoMatricula {
  ACTIVA
  VENCIDA
  CANCELADA
}

// ---------------------------------------------------------
// MODELOS (con tipos PostgreSQL nativos y mapeos)
// ---------------------------------------------------------

// Tabla: tutor (todo en minúsculas para evitar problemas)
model Tutor {
  id              String              @id @default(uuid()) @db.Uuid
  nombre          String
  apellidos       String
  carnetIdentidad String              @unique
  telefono        String?
  email           String?
  direccion       String?
  tipoPersona     TipoPersona
  activo          Boolean             @default(true)
  cantHijo        Int                 @default(1)

  // Relaciones
  hijos           Nino[]              @relation("Padres")
  solicitudes     Solicitud[]         @relation("TutorSolicitudes")
  documentosVal   DocumentoSolicitud[] @relation("Validador")
  trazas          Trazabilidad[]
  controles       ControlTrimestral[]

  @@map("tutor")
}

// Tabla: nino
model Nino {
  id              String   @id @default(uuid()) @db.Uuid
  nombre          String
  apellidos       String
  fechaNacimiento DateTime @db.Timestamp
  sexo            String
  tarjetaMenor    String   @unique
  tutorId         String   @db.Uuid

  // Relaciones
  tutor           Tutor?   @relation("Padres", fields: [tutorId], references: [id])
  casoEspecial    Boolean  @default(false)
  tipoNecesidad   String?
  solicitud       Solicitud?

  @@map("nino")
}

// Tabla: circulo_infantil
model CirculoInfantil {
  id              String             @id @default(uuid()) @db.Uuid
  nombre          String
  direccion       String
  municipio       String
  capacidadTotal  Int
  tipo            TipoCirculo
  activo          Boolean            @default(true)

  // Relaciones
  capacidades     CapacidadCirculo[]
  matriculas      Matricula[]

  @@map("circulo_infantil")
}

// Tabla: periodo_otorgamiento
model PeriodoOtorgamiento {
  id              String             @id @default(uuid()) @db.Uuid
  nombre          String
  fechaInicio     DateTime           @db.Timestamp
  fechaCierre     DateTime           @db.Timestamp
  fechaAsignacion DateTime           @db.Timestamp

  // Relaciones
  solicitudes     Solicitud[]
  capacidades     CapacidadCirculo[]
  sesiones        SesionComision[]

  @@map("periodo_otorgamiento")
}

// Tabla: capacidad_circulo
model CapacidadCirculo {
  id              String           @id @default(uuid()) @db.Uuid
  idCirculo       String           @db.Uuid
  idPeriodo       String           @db.Uuid
  cuposDisponibles Int
  cuposOcupados   Int

  // Relaciones
  circulo         CirculoInfantil  @relation(fields: [idCirculo], references: [id])
  periodo         PeriodoOtorgamiento @relation(fields: [idPeriodo], references: [id])

  @@unique([idCirculo, idPeriodo])
  @@map("capacidad_circulo")
}

// Tabla: solicitud
model Solicitud {
  id              String             @id @default(uuid()) @db.Uuid
  ninoId          String             @unique @db.Uuid
  tutorId         String             @db.Uuid
  fechaSolicitud  DateTime           @default(now()) @db.Timestamp
  sector          SectorPrioridad
  tipoSolicitud   TipoSolicitud
  estado          EstadoSolicitud
  periodoId       String             @db.Uuid
  numeroRegistro  String
  observaciones   String?

  // Relaciones
  nino            Nino               @relation(fields: [ninoId], references: [id])
  tutor           Tutor              @relation("TutorSolicitudes", fields: [tutorId], references: [id])
  periodo         PeriodoOtorgamiento @relation(fields: [periodoId], references: [id])
  documentos      DocumentoSolicitud[]
  decisiones      DecisionSolicitud[]
  matricula       Matricula?
  trazas          Trazabilidad[]

  @@map("solicitud")
}

// Tabla: documento_solicitud
model DocumentoSolicitud {
  id              String    @id @default(uuid()) @db.Uuid
  solicitudId     String    @db.Uuid
  tipoDocumento   TipoDocumento
  archivoUrl      String
  validado        Boolean   @default(false)
  fechaValidacion DateTime? @db.Timestamp
  validadorId     String?   @db.Uuid

  // Relaciones
  solicitud       Solicitud @relation(fields: [solicitudId], references: [id])
  validador       Tutor?    @relation("Validador", fields: [validadorId], references: [id])

  @@map("documento_solicitud")
}

// Tabla: comision
model Comision {
  id        String          @id @default(uuid()) @db.Uuid
  municipio String
  activo    Boolean         @default(true)

  // Relaciones
  sesiones  SesionComision[]

  @@map("comision")
}

// Tabla: sesion_comision
model SesionComision {
  id        String          @id @default(uuid()) @db.Uuid
  comisionId String         @db.Uuid
  periodoId  String         @db.Uuid
  fecha     DateTime        @db.Timestamp
  actaUrl   String?

  // Relaciones
  comision  Comision        @relation(fields: [comisionId], references: [id])
  periodo   PeriodoOtorgamiento @relation(fields: [periodoId], references: [id])
  decisiones DecisionSolicitud[]

  @@map("sesion_comision")
}

// Tabla: decision_solicitud
model DecisionSolicitud {
  id          String          @id @default(uuid()) @db.Uuid
  solicitudId String          @db.Uuid
  sesionId    String          @db.Uuid
  resultado   ResultadoDecision
  puntuacion  Int
  observaciones String?

  // Relaciones
  solicitud   Solicitud       @relation(fields: [solicitudId], references: [id])
  sesion      SesionComision  @relation(fields: [sesionId], references: [id])

  @@map("decision_solicitud")
}

// Tabla: matricula
model Matricula {
  id              String          @id @default(uuid()) @db.Uuid
  solicitudId     String          @unique @db.Uuid
  circuloId       String          @db.Uuid
  fechaOtorgamiento DateTime      @db.Timestamp
  fechaLimite     DateTime        @db.Timestamp
  estado          EstadoMatricula
  boletaUrl       String?

  // Relaciones
  solicitud       Solicitud       @relation(fields: [solicitudId], references: [id])
  circulo         CirculoInfantil @relation(fields: [circuloId], references: [id])
  controles       ControlTrimestral[]

  @@map("matricula")
}

// Tabla: control_trimestral
model ControlTrimestral {
  id          String      @id @default(uuid()) @db.Uuid
  matriculaId String      @db.Uuid
  fecha       DateTime    @db.Timestamp
  vinculo     VinculoLaboral
  observaciones String?
  funcionarioId String    @db.Uuid

  // Relaciones
  matricula   Matricula   @relation(fields: [matriculaId], references: [id])
  funcionario Tutor       @relation(fields: [funcionarioId], references: [id])

  @@map("control_trimestral")
}

// Tabla: trazabilidad
model Trazabilidad {
  id            String    @id @default(uuid()) @db.Uuid
  solicitudId   String    @db.Uuid
  estadoAnterior String
  estadoNuevo   String
  fecha         DateTime  @default(now()) @db.Timestamp
  usuarioId     String    @db.Uuid
  comentario    String?

  // Relaciones
  solicitud     Solicitud @relation(fields: [solicitudId], references: [id])
  usuario       Tutor     @relation(fields: [usuarioId], references: [id])

  @@map("trazabilidad")
}